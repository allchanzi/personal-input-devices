  #include <behaviors.dtsi>
  #include <dt-bindings/zmk/keys.h>

  / {
    keymap {
      compatible = "zmk,keymap";

      layer0 {
        /* Layer 0 - zakladna
         * Shift znaky su v zatvorke. Alt/Option sem nedopisujem, lebo zavisi od OS layoutu.
         * ESC   1(!) 2(@) 3(#) 4($) 5(%)    6(^) 7(&) 8(*) 9(() 0()) BSPC
         * TAB   Q    W    E    R    T        Y    U    I    O    P    -(_)
         * `(~)  A    S    D    F    G        H    J    K    L    ;(:) '(")
         * \(|)  Z    X    C    V    B   MUTE  ·    N    M    ,(<) .(>) /(?) RSHFT
         *
         * LCTRL LALT LGUI MO(1) SPACE   |   ENTER CAPS  [({) ](}) =(+ )

         */
        bindings = <
          &kp ESCAPE &kp N1 &kp N2 &kp N3 &kp N4 &kp N5 &kp N6 &kp N7 &kp N8 &kp N9 &kp N0 &kp BACKSPACE
          &kp TAB &kp Q &kp W &kp E &kp R &kp T &kp Y &kp U &kp I &kp O &kp P &kp MINUS
          &kp GRAVE &kp A &kp S &kp D &kp F &kp G &kp H &kp J &kp K &kp L &kp SEMICOLON &kp SINGLE_QUOTE
          &kp BACKSLASH &kp Z &kp X &kp C &kp V &kp B &kp C_MUTE &none &kp N &kp M &kp COMMA &kp DOT &kp SLASH &kp RIGHT_SHIFT
          &kp LEFT_CONTROL &kp LEFT_ALT &kp LEFT_GUI &mo 1 &kp SPACE &kp ENTER &kp CAPS &kp LEFT_BRACKET &kp RIGHT_BRACKET &kp EQUAL
        >;
        sensor-bindings = <&inc_dec_kp C_VOL_DN C_VOL_UP &inc_dec_kp LG(EQUAL) LG(MINUS)>;
      };

      layer2 {
        /* Layer 2 - funkcne / symboly / sipky
         * Shift znaky su v zatvorke. Alt/Option sem nedopisujem, lebo zavisi od OS layoutu.
         * TRNS  F1   F2   F3   F4   F5       F6   F7   F8   F9   F10  +(=)
         * `(~) 1(!) UP   3(#) 4($) 5(%)      6(^) 7(&) 8(*) 9(() [({) ](})
         * TRNS  LEFT DOWN RIGHT ·    ·        LEFT DOWN UP   RIGHT ·    |
         * TRNS  ~    -(_) ·    ·    ·        TRNS TRNS [({) ](}) ;(:) · \(|) TRNS
         */
        bindings = <
          &studio_unlock &kp F1 &kp F2 &kp F3 &kp F4 &kp F5 &kp F6 &kp F7 &kp F8 &kp F9 &kp F10 &kp EQUAL
          &kp GRAVE &kp N1 &kp UP &kp N3 &kp N4 &kp N5 &kp N6 &kp N7 &kp N8 &kp N9 &kp LEFT_BRACKET &kp RIGHT_BRACKET
          &trans &kp LEFT &kp DOWN &kp RIGHT &none &none &kp LEFT &kp DOWN &kp UP &kp RIGHT &none &kp PIPE
          &trans &kp TILDE &kp MINUS &none &none &none &trans &trans &kp LEFT_BRACKET &kp RIGHT_BRACKET &kp SEMICOLON &none &kp BACKSLASH &trans
          &trans &trans &trans &trans &trans &trans &trans &trans &trans &trans
        >;
        sensor-bindings = <&inc_dec_kp C_VOL_DN C_VOL_UP &inc_dec_kp LG(EQUAL) LG(MINUS)>;
      };
    };
  };
